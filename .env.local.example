# ── Supabase (Project Settings → API) ───────────────────────────────
# Public project URL, e.g. https://abcdxyz.supabase.co
SUPABASE_URL=
# Service-role key (server-side ONLY — never exposed to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin dashboard gate ────────────────────────────────────────────
# Password required to open /admin. Use something long and random.
ADMIN_PASSWORD=change-this-to-a-long-random-string

# ── Experiment configuration ────────────────────────────────────────
# Fraction of questions (0..1) where the "Ask AI" full answer is the
# MISLEADING one — this is the experimental manipulation that lets you
# measure whether participants blindly follow a wrong AI (WAAS).
NEXT_PUBLIC_AI_MISLEAD_RATE=0.35
# Randomise the order of the 5 cognitive levels per participant
# (counterbalancing). true / false.
NEXT_PUBLIC_RANDOMISE_LEVEL_ORDER=true
